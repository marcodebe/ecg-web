# Autenticazione via API key (header: X-API-Key)
# Imposta a false per disabilitare completamente l'autenticazione
AUTH_ENABLED=true

# Lista di API key valide, separate da virgola
API_KEYS=changeme-key-1,changeme-key-2

# Limite di richieste per IP (formato slowapi: N/period)
# Esempi: 60/minute, 10/second, 1000/hour
RATE_LIMIT=60/minute
